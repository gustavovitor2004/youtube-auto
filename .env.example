# ─── YouTube Automation System — Environment Variables ────────────────────────
# Copie este arquivo para .env e preencha os valores
# Renomeie: cp .env.example .env

# ─── PEXELS (GRÁTIS) ──────────────────────────────────────────────────────────
# 1. Acesse: https://www.pexels.com/api/
# 2. Crie conta gratuita
# 3. Clique em "Get Started" → copie sua API key
# Limite: 200 requests/hora | 20.000/mês — mais que suficiente
PEXELS_API_KEY=your_pexels_api_key_here

# ─── OLLAMA (GRÁTIS — LLM local) ──────────────────────────────────────────────
# 1. Instale: https://ollama.com/download
# 2. Execute: ollama pull llama3.2
# 3. Ollama roda em http://localhost:11434 automaticamente
OLLAMA_MODEL=llama3.2
# OLLAMA_MODEL=mistral          # Alternativa (menor, mais rápido)
# OLLAMA_MODEL=llama3.2:1b      # Ultra leve para PCs fracos

# ─── CONFIGURAÇÕES DO CANAL ───────────────────────────────────────────────────
CHANNEL_NICHE=dark psychology
# Outras opções: "true crime" | "finance facts" | "psychology facts" | "history mysteries"
